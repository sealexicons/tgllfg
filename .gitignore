# .gitignore

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so
*.pyd
*.dylib

# Packaging / build artifacts
build/
dist/
*.whl

# Hatch / hatchling
.hatch/
.hatch-venv/
.hatch/*

# Virtualenvs commonly created by hatch or locally
.venv/

# Testing / coverage / caches
.pytest_cache/
.tox/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.cache/

# Environment files
.env
.env.*

# Editor/OS files
.vscode/
.idea/
.DS_Store
Thumbs.db

# Miscellaneous
*~
*.bak
*.log
tmp/

# Reference works staged locally for grep / corpus mining;
# excluded from the repo for binary-size and licensing reasons.
data/tgl/references/

# Exemplar harvest corpus — TRACKED as of Phase 12.F (2026-06-05).
# Promoted from gitignored to tracked: fair use applies and every
# exemplar carries its `source` + `locator` citation, so the harvested
# example sentences ship with the repo and CI can run the audit on a
# fresh clone. The licensed reference PDFs themselves stay ignored
# (references/, above). Derived / transient artifacts stay ignored —
# all regenerable from the source corpus:
data/tgl/exemplars/*-parse-results.jsonl
data/tgl/exemplars/*.tmp
data/tgl/exemplars/coverage-*.md
data/tgl/exemplars/oov-frequency.tsv

# Per-project plan files (live alongside the repo for convenience but
# remain personal working notes, not project artifacts).
.claude/plans/

# Per-session lock state written by the Claude Code harness.
.claude/scheduled_tasks.lock

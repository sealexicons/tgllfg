# .gitignore

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so
*.pyd
*.dylib

# Packaging / build artifacts
build/
dist/
*.whl

# Hatch / hatchling
.hatch/
.hatch-venv/
.hatch/*

# Virtualenvs commonly created by hatch or locally
.venv/

# Testing / coverage / caches
.pytest_cache/
.tox/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.cache/

# Environment files
.env
.env.*

# Editor/OS files
.vscode/
.idea/
.DS_Store
Thumbs.db

# Miscellaneous
*~
*.bak
*.log
tmp/

# Reference works staged locally for grep / corpus mining;
# excluded from the repo for binary-size and licensing reasons.
data/tgl/references/

# Exemplar harvest output (derived from gitignored references/).
# Contents are ignored EXCEPT the hand-authored unattributed-construction
# corpus (Phase 10.E.5) — `unattributed*.*` is tracked so its regression
# test reads it on a fresh clone. Listing the dir contents (`/*`) rather
# than the dir itself keeps the dir traversable so the negation can
# re-include. Derived parse-results stay ignored (regenerable via
# `scripts/harvest_exemplars.py parse`).
data/tgl/exemplars/*
!data/tgl/exemplars/unattributed*.*
data/tgl/exemplars/*-parse-results.jsonl

# Per-project plan files (live alongside the repo for convenience but
# remain personal working notes, not project artifacts).
.claude/plans/

# Per-session lock state written by the Claude Code harness.
.claude/scheduled_tasks.lock

# .gitignore — monorepo top level. Cross-cutting ignores only; tree-
# specific patterns live in tlbe/.gitignore (Python) and tlfe/.gitignore
# (JS). No leading slash, so each pattern matches at any depth.

# Environment files (backend secrets / Vite env, in either tree)
.env
.env.*

# Editor / OS files (appear in any directory)
.vscode/
.idea/
.DS_Store
Thumbs.db

# Miscellaneous
*~
*.bak
*.log

# Scratch dir — ignored at any depth, so tlbe/tmp/ (and any future
# top-level or tlfe/ tmp/) are covered by this one pattern.
tmp/

# Per-project plan files (live alongside the repo for convenience but
# remain personal working notes, not project artifacts).
.claude/plans/

# Per-session lock state written by the Claude Code harness.
.claude/scheduled_tasks.lock
